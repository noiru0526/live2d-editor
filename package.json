{
  "name": "live2d-editor",
  "version": "1.0.0",
  "description": "Live2D風メッシュ変形エディタ — noiru",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.noiru.live2d-editor",
    "productName": "Live2D Editor",
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ]
  },
  "dependencies": {
    "discord-rpc": "^4.0.1"
  }
}
